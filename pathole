import subprocess
import time
from pyngrok import ngrok

streamlit_code = """
import streamlit as st
from tensorflow.keras.models import load_model
from tensorflow.keras.preprocessing import image
import numpy as np
from PIL import Image

st.title("🕳️ Pothole & Manhole Detection App")

# Load models
pothole_model = load_model("/content/pothole_model.h5")
manhole_model = load_model("/content/open_closed_manhole_model.h5")

def preprocess(img):
    img = img.resize((150, 150))
    arr = image.img_to_array(img) / 255.0
    return np.expand_dims(arr, axis=0)

uploaded_file = st.file_uploader("Upload a road image", type=["jpg", "jpeg", "png"])
if uploaded_file:
    img = Image.open(uploaded_file)
    st.image(img, caption="Uploaded Image", use_column_width=True)
    input_img = preprocess(img)

    pothole_pred = pothole_model.predict(input_img)[0][0]
    if pothole_pred > 0.5:
        st.error("🕳️ Pothole Detected!")

        manhole_pred = manhole_model.predict(input_img)[0][0]
        if manhole_pred > 0.5:
            st.warning("🚨 Open Manhole Detected")
        else:
            st.success("✅ Closed Manhole Detected")
    else:
        st.success("✅ No Pothole Detected")
"""

# Save code to a temp file
with open("app_temp.py", "w") as f:
    f.write(streamlit_code)

# Start Streamlit app
subprocess.Popen(["streamlit", "run", "app_temp.py"])

# Wait for Streamlit to start
time.sleep(5)

# Connect ngrok tunnel
public_url = ngrok.connect(8501)
print("🌐 Open this Streamlit app in a new tab:", public_url)
