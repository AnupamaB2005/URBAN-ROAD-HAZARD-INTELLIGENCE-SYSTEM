import pandas as pd
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import classification_report
from imblearn.over_sampling import SMOTE
from sklearn.preprocessing import LabelEncoder
import shap

# Load your dataset
df = pd.read_csv("/content/test.csv.zip")  # Update this path if needed

# Use correct label column
df = df.dropna(subset=["Casualty_severity"])
X = pd.get_dummies(df.drop(["Casualty_severity", "Num"], axis=1), drop_first=True)
y = df["Casualty_severity"]

# Encode labels
le = LabelEncoder()
y = le.fit_transform(y)

# Balance classes
X_res, y_res = SMOTE(random_state=42).fit_resample(X, y)

# Split
X_train, X_test, y_train, y_test = train_test_split(X_res, y_res, test_size=0.2, random_state=42)

# Train
model = RandomForestClassifier(n_estimators=100, random_state=42)
model.fit(X_train, y_train)

# Evaluate
y_pred = model.predict(X_test)
print(classification_report(y_test, y_pred, target_names=le.classes_))

# SHAP
explainer = shap.TreeExplainer(model)
shap_values = explainer.shap_values(X_test)
shap.summary_plot(shap_values, X_test)





from tensorflow.keras.models import load_model
from tensorflow.keras.preprocessing import image
import numpy as np
import matplotlib.pyplot as plt

# Load model
model = load_model("pothole_model.h5")

# Load and preprocess image
img_path = "/content/pothole 1.jpeg"  # or from 'normal'
img = image.load_img(img_path, target_size=(150, 150))
img_array = image.img_to_array(img) / 255.0
img_array = np.expand_dims(img_array, axis=0)

# Predict
pred = model.predict(img_array)[0][0]
result = "Pothole" if pred > 0.5 else "Normal"

# Show result
plt.imshow(img)
plt.title(f"Prediction: {result}")
plt.axis('off')
plt.show()
